{
  "name": "knowledgeos-browser-extension",
  "displayName": "Knowledgeos browser extension",
  "version": "0.0.1",
  "description": "Add your links to KnowledgeOS effortlessly",
  "author": "pierogbartoszzstti@gmail.com",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "lucide-react": "^0.575.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "activeTab"
    ],
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "{0cb7157b-42b2-4ace-b78f-3903cbcbd6fc}",
        "strict_min_version": "109.0",
        "data_collection_permissions": {
          "required": ["browsingActivity","websiteContent","websiteActivity"],
          "optional": []
        }
      }
    }
  }

}
